# ── API Keys (at least one required) ──────────────────────────────
# The script auto-detects providers from available keys.

# OpenRouter (https://openrouter.ai) — free tier models
OPENROUTER_API_KEY=

# NVIDIA API (https://build.nvidia.com) — free credits
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com

# ── Model Override (optional) ─────────────────────────────────────
# Comma-separated provider/model pairs. Overrides defaults if set.
# MODEL_LIST=openrouter/google/gemma-4-31b-it:free,nvidia/google/gemma-4-31b-it

# ── HuggingFace (for upload) ─────────────────────────────────────
HF_TOKEN=
